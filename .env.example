# PetBloom Environment Variables Configuration Template
# Copy this file to '.env' and fill in the secrets for local development.

# Supabase Configurations
VITE_SUPABASE_URL=https://your-supabase-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-string

# Gemini API Credentials
VITE_GEMINI_API_KEY=your-gemini-api-key

# Weather API Coordinates Integration
VITE_WEATHER_API_KEY=your-openweather-api-key

# Google Maps Places API for Vet Locators
VITE_GOOGLE_MAPS_KEY=your-google-maps-api-key
